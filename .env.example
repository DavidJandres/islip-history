# Public base URL of the deployed site. Used for canonical URLs, the sitemap,
# and Open Graph tags. Set this in Vercel's project environment variables.
NEXT_PUBLIC_SITE_URL=https://islip-history.example.org

# --- Visitor counter (optional) ---
# Homepage visit count. Backed by Upstash Redis. In Vercel → Storage, add
# Upstash Redis (or the Redis integration) and it injects these two automatically.
# Until they are set, the counter simply doesn't render.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- "Ask a question" form (optional) ---
# Delivers form submissions by email via Resend (https://resend.com — free tier).
# The form activates only when BOTH of these are set; until then it reports that
# it isn't configured yet (no failed sends shown to visitors).
RESEND_API_KEY=
# Verified sender for the emails. Verify a domain in Resend (add its DNS records),
# then set this to an address at that domain, e.g.
# "Islip History <questions@theislippromise.org>".
CONTACT_FROM_EMAIL=
